APP_NAME="Landing Backend"
APP_ENV=development
APP_DEBUG=true

API_V1_PREFIX=/api

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

OWNER_EMAIL=owner@example.com

# AI provider: OpenRouter (OpenAI-compatible API).
# Get a key at https://openrouter.ai/keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Any OpenRouter model id, e.g. openai/gpt-4o-mini
# Free models look like: meta-llama/llama-3.1-8b-instruct:free
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=8

RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

STORAGE_DIR=app/storage
# Database connection string (SQLite by default, or postgresql://user:password@localhost:5432/landing_db)
DATABASE_URL=sqlite:///./app/storage/landing.db

LOG_DIR=logs
REQUEST_LOG_FILE=logs/requests.log
APP_LOG_FILE=logs/app.log

